{
  "dashboard": {
    "id": null,
    "title": "ML Model Performance",
    "tags": ["ml", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Model Prediction Accuracy",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(scroll_predictions_correct_total[5m]) / rate(scroll_predictions_total[5m])",
            "legendFormat": "Accuracy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.85}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Prediction Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ml_prediction_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(ml_prediction_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile"
          }
        ],
        "yAxes": [
          {"unit": "s", "min": 0}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Feature Extraction Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(feature_extraction_duration_seconds_sum[5m]) / rate(feature_extraction_duration_seconds_count[5m])",
            "legendFormat": "Average extraction time"
          }
        ],
        "yAxes": [
          {"unit": "ms", "min": 0}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Model Memory Usage",
        "type": "stat",
        "targets": [
          {
            "expr": "ml_model_memory_bytes",
            "legendFormat": "Memory"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 104857600},
                {"color": "red", "value": 209715200}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}