{
  "dashboard": {
    "id": null,
    "title": "PostgreSQL ML Model Storage",
    "tags": ["postgresql", "ml", "database"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Model Storage Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_stat_activity_count{datname=\"scroll_models\"}",
            "legendFormat": "Active Connections"
          }
        ]
      },
      {
        "id": 2,
        "title": "Model Query Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pg_stat_database_tup_fetched{datname=\"scroll_models\"}[5m])",
            "legendFormat": "Rows Fetched/sec"
          }
        ]
      },
      {
        "id": 3,
        "title": "Model Storage Size",
        "type": "singlestat",
        "targets": [
          {
            "expr": "pg_database_size_bytes{datname=\"scroll_models\"}",
            "legendFormat": "Database Size"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}